{
  "name": "md-tmpl",
  "version": "0.4.1",
  "description": "Strongly-typed template engine for LLM prompts, designed for markdown",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "!dist/tests",
    "!dist/benchmarks",
    "!src/tests",
    "!src/benchmarks"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --test dist/tests/*.test.js",
    "bench": "node dist/benchmarks/bench.js",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "template",
    "prompt",
    "llm",
    "typed",
    "frontmatter"
  ],
  "author": "domenukk",
  "license": "MIT OR Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/domenukk/md-tmpl",
    "directory": "crates/md-tmpl-typescript"
  },
  "homepage": "https://github.com/domenukk/md-tmpl#readme",
  "bugs": {
    "url": "https://github.com/domenukk/md-tmpl/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/mustache": "^4.2.6",
    "@types/node": "^25.9.3",
    "handlebars": "^4.7.9",
    "mustache": "^4.2.0",
    "typescript": "^5.7.0"
  }
}
