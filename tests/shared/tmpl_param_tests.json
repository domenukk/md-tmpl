{
  "tests": [
    {
      "name": "tmpl_param_basic_include",
      "description": "tmpl() param can be included with parameters",
      "template_lines": [
        "---",
        "params: [name = str]",
        "---",
        "> {% tmpl greeting %}",
        "---",
        "params: [name = str]",
        "---",
        "Hello {{ name }}!",
        "",
        "> {% /tmpl %}",
        "",
        "> {% include greeting with name=name %}"
      ],
      "params": {
        "name": "World"
      },
      "expected_output": "Hello World!\n"
    },
    {
      "name": "tmpl_param_multiple_params",
      "description": "Inline template with multiple typed parameters (str + int)",
      "template_lines": [
        "---",
        "params:",
        "  - label = str",
        "  - count = int",
        "---",
        "> {% tmpl widget %}",
        "---",
        "params:",
        "  - label = str",
        "  - count = int",
        "---",
        "{{ label }}: {{ count }}",
        "",
        "> {% /tmpl %}",
        "",
        "> {% include widget with label=label, count=count %}"
      ],
      "params": {
        "label": "items",
        "count": 7
      },
      "expected_output": "items: 7\n"
    },
    {
      "name": "tmpl_param_type_mismatch_str_for_int",
      "description": "Passing str where int is expected produces a type mismatch error",
      "template_lines": [
        "---",
        "params: [name = str]",
        "---",
        "> {% tmpl counter %}",
        "---",
        "params: [count = int]",
        "---",
        "{{ count }}",
        "",
        "> {% /tmpl %}",
        "",
        "> {% include counter with count=name %}"
      ],
      "params": {
        "name": "oops"
      },
      "expected_error": "type mismatch"
    },
    {
      "name": "tmpl_param_with_defaults",
      "description": "Inline template with default param values uses defaults when not overridden",
      "template_lines": [
        "---",
        "params: [name = str]",
        "---",
        "> {% tmpl greeter %}",
        "---",
        "params:",
        "  - name = str",
        "  - greeting = str := \"Hi\"",
        "---",
        "{{ greeting }} {{ name }}!",
        "",
        "> {% /tmpl %}",
        "",
        "> {% include greeter with name=name %}"
      ],
      "params": {
        "name": "World"
      },
      "expected_output": "Hi World!\n"
    },
    {
      "name": "tmpl_param_override_default",
      "description": "Explicitly passed value overrides the default",
      "template_lines": [
        "---",
        "params:",
        "  - name = str",
        "  - greeting = str",
        "---",
        "> {% tmpl greeter %}",
        "---",
        "params:",
        "  - name = str",
        "  - greeting = str := \"Hi\"",
        "---",
        "{{ greeting }} {{ name }}!",
        "",
        "> {% /tmpl %}",
        "",
        "> {% include greeter with name=name, greeting=greeting %}"
      ],
      "params": {
        "name": "World",
        "greeting": "Hey"
      },
      "expected_output": "Hey World!\n"
    },
    {
      "name": "tmpl_param_empty_no_params",
      "description": "Zero-param inline template works with bare include",
      "template_lines": [
        "---",
        "params: []",
        "---",
        "> {% tmpl preamble %}",
        "---",
        "params: []",
        "---",
        "Static content.",
        "",
        "> {% /tmpl %}",
        "",
        "> {% include preamble %}"
      ],
      "params": {},
      "expected_output": "Static content.\n"
    },
    {
      "name": "tmpl_param_missing_required_param",
      "description": "Including a template without required params produces an error",
      "template_lines": [
        "---",
        "params: []",
        "---",
        "> {% tmpl needs_stuff %}",
        "---",
        "params:",
        "  - title = str",
        "  - count = int",
        "---",
        "{{ title }} ({{ count }})",
        "",
        "> {% /tmpl %}",
        "",
        "> {% include needs_stuff %}"
      ],
      "params": {},
      "expected_error": "title"
    },
    {
      "name": "tmpl_param_nested_includes",
      "description": "Inline templates can include other inline templates",
      "template_lines": [
        "---",
        "params: [name = str]",
        "---",
        "> {% tmpl inner %}",
        "---",
        "params: [val = str]",
        "---",
        "[{{ val }}]",
        "",
        "> {% /tmpl %}",
        "",
        "> {% tmpl outer %}",
        "---",
        "params: [name = str]",
        "---",
        "",
        "> {% include inner with val=name %}",
        "",
        "> {% /tmpl %}",
        "",
        "> {% include outer with name=name %}"
      ],
      "params": {
        "name": "deep"
      },
      "expected_output": "[deep]\n"
    }
  ]
}
