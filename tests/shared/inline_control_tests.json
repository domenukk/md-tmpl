{
  "tests": [
    {
      "name": "inline_if_true",
      "description": "Inline if renders body when condition is true",
      "template_lines": [
        "---",
        "params: [flag = bool]",
        "---",
        "> {% if flag %}yes{% /if %}"
      ],
      "params": {
        "flag": true
      },
      "expected_output": "yes"
    },
    {
      "name": "inline_if_false",
      "description": "Inline if renders nothing when condition is false",
      "template_lines": [
        "---",
        "params: [flag = bool]",
        "---",
        "> {% if flag %}yes{% /if %}"
      ],
      "params": {
        "flag": false
      },
      "expected_output": ""
    },
    {
      "name": "inline_if_else_true",
      "description": "Inline if-else renders if-branch when true",
      "template_lines": [
        "---",
        "params: [flag = bool]",
        "---",
        "> {% if flag %}yes{% else %}no{% /if %}"
      ],
      "params": {
        "flag": true
      },
      "expected_output": "yes"
    },
    {
      "name": "inline_if_else_false",
      "description": "Inline if-else renders else-branch when false",
      "template_lines": [
        "---",
        "params: [flag = bool]",
        "---",
        "> {% if flag %}yes{% else %}no{% /if %}"
      ],
      "params": {
        "flag": false
      },
      "expected_output": "no"
    },
    {
      "name": "inline_elif_chain_first",
      "description": "Inline elif chain renders first matching branch",
      "template_lines": [
        "---",
        "params: [x = int]",
        "---",
        "> {% if x == 1 %}A{% elif x == 2 %}B{% else %}C{% /if %}"
      ],
      "params": {
        "x": 1
      },
      "expected_output": "A"
    },
    {
      "name": "inline_elif_chain_second",
      "description": "Inline elif chain renders second branch when matched",
      "template_lines": [
        "---",
        "params: [x = int]",
        "---",
        "> {% if x == 1 %}A{% elif x == 2 %}B{% else %}C{% /if %}"
      ],
      "params": {
        "x": 2
      },
      "expected_output": "B"
    },
    {
      "name": "inline_elif_chain_else",
      "description": "Inline elif chain falls through to else",
      "template_lines": [
        "---",
        "params: [x = int]",
        "---",
        "> {% if x == 1 %}A{% elif x == 2 %}B{% else %}C{% /if %}"
      ],
      "params": {
        "x": 99
      },
      "expected_output": "C"
    },
    {
      "name": "inline_for_loop",
      "description": "Inline for loop iterates over struct list",
      "template_lines": [
        "---",
        "params: [items = list(name = str)]",
        "---",
        "> {% for item in items %}{{ item.name }} {% /for %}"
      ],
      "params": {
        "items": [
          {
            "name": "a"
          },
          {
            "name": "b"
          },
          {
            "name": "c"
          }
        ]
      },
      "expected_output": "a b c "
    },
    {
      "name": "for_else_empty_list",
      "description": "For-else renders else body when list is empty",
      "template_lines": [
        "---",
        "params: [items = list(str)]",
        "---",
        "> {% for item in items %}{{ item }}{% else %}empty{% /for %}"
      ],
      "params": {
        "items": []
      },
      "expected_output": "empty"
    },
    {
      "name": "for_else_nonempty_list",
      "description": "For-else renders items when list is non-empty",
      "template_lines": [
        "---",
        "params: [items = list(str)]",
        "---",
        "> {% for item in items %}{{ item }} {% else %}empty{% /for %}"
      ],
      "params": {
        "items": [
          "x",
          "y"
        ]
      },
      "expected_output": "x y "
    },
    {
      "name": "nested_inline_if_both_true",
      "description": "Nested inline if renders when both conditions are true",
      "template_lines": [
        "---",
        "params: [a = bool, b = bool]",
        "---",
        "> {% if a %}{% if b %}DEEP{% /if %}{% /if %}"
      ],
      "params": {
        "a": true,
        "b": true
      },
      "expected_output": "DEEP"
    },
    {
      "name": "nested_inline_if_outer_true_inner_false",
      "description": "Nested inline if \u2014 outer true, inner false",
      "template_lines": [
        "---",
        "params: [a = bool, b = bool]",
        "---",
        "> {% if a %}{% if b %}DEEP{% /if %}{% /if %}"
      ],
      "params": {
        "a": true,
        "b": false
      },
      "expected_output": ""
    },
    {
      "name": "nested_inline_if_outer_false",
      "description": "Nested inline if \u2014 outer false skips everything",
      "template_lines": [
        "---",
        "params: [a = bool, b = bool]",
        "---",
        "> {% if a %}{% if b %}DEEP{% /if %}{% /if %}"
      ],
      "params": {
        "a": false,
        "b": true
      },
      "expected_output": ""
    },
    {
      "name": "text_around_inline_if_true",
      "description": "Text before and after inline if \u2014 condition true",
      "template_lines": [
        "---",
        "params: [flag = bool]",
        "---",
        "prefix-{% if flag %}MIDDLE{% /if %}-suffix"
      ],
      "params": {
        "flag": true
      },
      "expected_output": "prefix-MIDDLE-suffix"
    },
    {
      "name": "text_around_inline_if_false",
      "description": "Text before and after inline if \u2014 condition false",
      "template_lines": [
        "---",
        "params: [flag = bool]",
        "---",
        "prefix-{% if flag %}MIDDLE{% /if %}-suffix"
      ],
      "params": {
        "flag": false
      },
      "expected_output": "prefix--suffix"
    },
    {
      "name": "inline_match_with_else_matched",
      "description": "Inline match-else renders matched body when variant matches",
      "template_lines": [
        "---",
        "params: [x = str]",
        "---",
        "> {% match x case Active %}ON{% else %}OFF{% /match %}"
      ],
      "params": {
        "x": "Active"
      },
      "expected_output": "ON"
    },
    {
      "name": "inline_match_with_else_unmatched",
      "description": "Inline match-else renders else body when variant doesn't match",
      "template_lines": [
        "---",
        "params: [x = str]",
        "---",
        "> {% match x case Active %}ON{% else %}OFF{% /match %}"
      ],
      "params": {
        "x": "Stopped"
      },
      "expected_output": "OFF"
    },
    {
      "name": "unicode_in_inline_if",
      "description": "Unicode content inside inline if renders correctly",
      "template_lines": [
        "---",
        "params: [flag = bool]",
        "---",
        "> {% if flag %}\ud83c\udfaf \u65e5\u672c\u8a9e{% /if %}"
      ],
      "params": {
        "flag": true
      },
      "expected_output": "\ud83c\udfaf \u65e5\u672c\u8a9e"
    },
    {
      "name": "const_ref_as_param_default",
      "description": "Const name used as param default resolves to const value",
      "template_lines": [
        "---",
        "consts:",
        "  - MAX = int := 10",
        "",
        "params:",
        "  - count = int := MAX",
        "---",
        "{{ count }}"
      ],
      "params": {},
      "expected_output": "10"
    },
    {
      "name": "filter_inside_inline_if_true",
      "description": "Filter applied to expression inside inline if when true",
      "template_lines": [
        "---",
        "params: [flag = bool, name = str]",
        "---",
        "> {% if flag %}{{ name | upper }}{% /if %}"
      ],
      "params": {
        "flag": true,
        "name": "hello"
      },
      "expected_output": "HELLO"
    },
    {
      "name": "filter_inside_inline_if_false",
      "description": "Filter inside inline if \u2014 condition false renders nothing",
      "template_lines": [
        "---",
        "params: [flag = bool, name = str]",
        "---",
        "> {% if flag %}{{ name | upper }}{% /if %}"
      ],
      "params": {
        "flag": false,
        "name": "hello"
      },
      "expected_output": ""
    },
    {
      "name": "filter_inside_inline_for",
      "description": "Filter applied to expression inside inline for loop",
      "template_lines": [
        "---",
        "params: [items = list(name = str)]",
        "---",
        "> {% for item in items %}{{ item.name | lower }} {% /for %}"
      ],
      "params": {
        "items": [
          {
            "name": "FOO"
          },
          {
            "name": "BAR"
          }
        ]
      },
      "expected_output": "foo bar "
    },
    {
      "name": "nested_inline_for",
      "description": "Nested inline for loops iterate over nested lists",
      "template_lines": [
        "---",
        "params: [groups = list(items = list(str))]",
        "---",
        "> {% for group in groups %}[{% for item in group.items %}{{ item }}{% /for %}]{% /for %}"
      ],
      "params": {
        "groups": [
          {
            "items": [
              "a",
              "b"
            ]
          },
          {
            "items": [
              "c"
            ]
          }
        ]
      },
      "expected_output": "[ab][c]"
    },
    {
      "name": "inline_match_typed_enum_matched",
      "description": "Inline match with typed enum \u2014 matched variant",
      "template_lines": [
        "---",
        "types:",
        "  - Status = enum(Active, Paused, Stopped)",
        "",
        "params: [s = Status]",
        "---",
        "> {% match s case Active %}on{% else %}off{% /match %}"
      ],
      "params": {
        "s": "Active"
      },
      "expected_output": "on"
    },
    {
      "name": "inline_match_typed_enum_unmatched",
      "description": "Inline match with typed enum \u2014 unmatched falls to else",
      "template_lines": [
        "---",
        "types:",
        "  - Status = enum(Active, Paused, Stopped)",
        "",
        "params: [s = Status]",
        "---",
        "> {% match s case Active %}on{% else %}off{% /match %}"
      ],
      "params": {
        "s": "Paused"
      },
      "expected_output": "off"
    },
    {
      "name": "multiple_inline_blocks_on_separate_lines",
      "description": "Multiple blockquoted inline blocks on separate lines \u2014 no newline between",
      "template_lines": [
        "---",
        "params: [a = bool, b = bool]",
        "---",
        "> {% if a %}A{% /if %}",
        "> {% if b %}B{% /if %}"
      ],
      "params": {
        "a": true,
        "b": true
      },
      "expected_output": "AB"
    },
    {
      "name": "inline_if_comparison_gt_positive",
      "description": "Inline if with > comparison \u2014 positive result",
      "template_lines": [
        "---",
        "params: [count = int]",
        "---",
        "> {% if count > 0 %}positive{% else %}zero{% /if %}"
      ],
      "params": {
        "count": 5
      },
      "expected_output": "positive"
    },
    {
      "name": "inline_if_comparison_gt_zero",
      "description": "Inline if with > comparison \u2014 zero falls to else",
      "template_lines": [
        "---",
        "params: [count = int]",
        "---",
        "> {% if count > 0 %}positive{% else %}zero{% /if %}"
      ],
      "params": {
        "count": 0
      },
      "expected_output": "zero"
    },
    {
      "name": "inline_if_eq_string_match",
      "description": "Inline if with string equality \u2014 matched",
      "template_lines": [
        "---",
        "params: [mode = str]",
        "---",
        "> {% if mode == \"debug\" %}\ud83d\udc1b{% else %}\ud83d\ude80{% /if %}"
      ],
      "params": {
        "mode": "debug"
      },
      "expected_output": "\ud83d\udc1b"
    },
    {
      "name": "inline_if_eq_string_no_match",
      "description": "Inline if with string equality \u2014 not matched falls to else",
      "template_lines": [
        "---",
        "params: [mode = str]",
        "---",
        "> {% if mode == \"debug\" %}\ud83d\udc1b{% else %}\ud83d\ude80{% /if %}"
      ],
      "params": {
        "mode": "release"
      },
      "expected_output": "\ud83d\ude80"
    },
    {
      "name": "inline_match_no_else_matched",
      "description": "Inline match without else \u2014 matched renders body",
      "template_lines": [
        "---",
        "params: [x = str]",
        "---",
        "> {% match x case Active %}ON{% /match %}"
      ],
      "params": {
        "x": "Active"
      },
      "expected_output": "ON"
    },
    {
      "name": "inline_match_no_else_unmatched",
      "description": "Inline match without else \u2014 unmatched renders empty",
      "template_lines": [
        "---",
        "params: [x = str]",
        "---",
        "> {% match x case Active %}ON{% /match %}"
      ],
      "params": {
        "x": "Other"
      },
      "expected_output": ""
    },
    {
      "name": "const_str_as_param_default",
      "description": "String const used as param default resolves to const value",
      "template_lines": [
        "---",
        "consts:",
        "  - GREETING = str := \"Hello\"",
        "",
        "params:",
        "  - msg = str := GREETING",
        "---",
        "{{ msg }}"
      ],
      "params": {},
      "expected_output": "Hello"
    },
    {
      "name": "const_str_default_overridden",
      "description": "String const default can be overridden by caller",
      "template_lines": [
        "---",
        "consts:",
        "  - GREETING = str := \"Hello\"",
        "",
        "params:",
        "  - msg = str := GREETING",
        "---",
        "{{ msg }}"
      ],
      "params": {
        "msg": "Hi"
      },
      "expected_output": "Hi"
    },
    {
      "name": "const_bool_as_param_default",
      "description": "Bool const used as param default resolves to const value",
      "template_lines": [
        "---",
        "consts:",
        "  - DEFAULT_FLAG = bool := true",
        "",
        "params:",
        "  - flag = bool := DEFAULT_FLAG",
        "---",
        "> {% if flag %}yes{% else %}no{% /if %}"
      ],
      "params": {},
      "expected_output": "yes"
    },
    {
      "name": "const_bool_default_overridden",
      "description": "Bool const default can be overridden by caller",
      "template_lines": [
        "---",
        "consts:",
        "  - DEFAULT_FLAG = bool := true",
        "",
        "params:",
        "  - flag = bool := DEFAULT_FLAG",
        "---",
        "> {% if flag %}yes{% else %}no{% /if %}"
      ],
      "params": {
        "flag": false
      },
      "expected_output": "no"
    },
    {
      "name": "empty_inline_if_true",
      "description": "Empty inline if body \u2014 true condition renders nothing extra",
      "template_lines": [
        "---",
        "params: [flag = bool]",
        "---",
        "before{% if flag %}{% /if %}after"
      ],
      "params": {
        "flag": true
      },
      "expected_output": "beforeafter"
    },
    {
      "name": "empty_inline_if_false",
      "description": "Empty inline if body \u2014 false condition also renders nothing",
      "template_lines": [
        "---",
        "params: [flag = bool]",
        "---",
        "before{% if flag %}{% /if %}after"
      ],
      "params": {
        "flag": false
      },
      "expected_output": "beforeafter"
    },
    {
      "name": "for_loop_concat",
      "description": "Inline for loop concatenates items without separator",
      "template_lines": [
        "---",
        "params: [items = list(str)]",
        "---",
        "> {% for item in items %}{{ item }}{% /for %}"
      ],
      "params": {
        "items": [
          "x",
          "y",
          "z"
        ]
      },
      "expected_output": "xyz"
    },
    {
      "name": "inline_tmpl_own_consts",
      "description": "Inline template with its own consts renders them correctly",
      "template_lines": [
        "---",
        "params: []",
        "---",
        "> {% tmpl versioned %}",
        "---",
        "consts:",
        "  - V = str := \"2.0\"",
        "",
        "params: []",
        "---",
        "v{{ V }}",
        "",
        "> {% /tmpl %}",
        "",
        "> {% include versioned %}"
      ],
      "params": {},
      "expected_output": "v2.0\n"
    },
    {
      "name": "join_filter_on_list",
      "description": "Join filter concatenates list items with separator",
      "template_lines": [
        "---",
        "params: [tags = list(str)]",
        "---",
        "[{{ tags | join(\", \") }}]"
      ],
      "params": {
        "tags": [
          "rust",
          "ts",
          "go"
        ]
      },
      "expected_output": "[rust, ts, go]"
    },
    {
      "name": "control_deeply_nested_struct_in_loop",
      "description": "For loop accessing deeply nested struct fields across lists",
      "template_lines": [
        "---",
        "params: [org = struct(name = str, teams = list(name = str, members = list(name = str, role = str)))]",
        "---",
        "{{ org.name }}:",
        "",
        "> {% for team in org.teams %}",
        "",
        "Team {{ team.name }}:",
        "",
        "> {% for member in team.members %}",
        "",
        "- {{ member.name }} ({{ member.role }})",
        "",
        "> {% /for %}",
        "",
        "> {% /for %}"
      ],
      "params": {
        "org": {
          "name": "Eng",
          "teams": [
            {
              "name": "Core",
              "members": [
                {
                  "name": "Alice",
                  "role": "Lead"
                },
                {
                  "name": "Bob",
                  "role": "Dev"
                }
              ]
            }
          ]
        }
      },
      "expected_output": "Eng:\nTeam Core:\n- Alice (Lead)\n- Bob (Dev)\n"
    },
    {
      "name": "control_whitespace_stripping_loop_if",
      "description": "Aggressive whitespace stripping in combined for and if blocks",
      "template_lines": [
        "---",
        "params: [nums = list(int)]",
        "---",
        "[X{%- for n in nums -%}{%- if n > 0 -%}{{ n }}{%- /if -%}{%- /for -%}Y]"
      ],
      "params": {
        "nums": [
          -1,
          2,
          -3,
          4
        ]
      },
      "expected_output": "[X24Y]"
    },
    {
      "name": "control_match_option_narrowing_complex",
      "description": "Match statement on option<struct<...>> narrowing fields",
      "template_lines": [
        "---",
        "params: [config = option(struct(host = str, port = int))]",
        "---",
        "> {% match config %}",
        "",
        "> {% case Some %}",
        "",
        "{{ config.host }}:{{ config.port }}",
        "",
        "> {% case None %}",
        "",
        "default:80",
        "",
        "> {% /match %}"
      ],
      "params": {
        "config": {
          "host": "localhost",
          "port": 8080
        }
      },
      "expected_output": "localhost:8080\n"
    }
  ]
}