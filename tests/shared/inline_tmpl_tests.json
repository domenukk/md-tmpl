{
  "tests": [
    {
      "name": "basic_inline_template",
      "description": "Basic inline template definition and inclusion",
      "template_lines": [
        "---",
        "params: [name = str]",
        "---",
        "> {% tmpl greeting %}",
        "---",
        "params: [name = str]",
        "---",
        "Hello {{ name }}!",
        "",
        "> {% /tmpl %}",
        "",
        "> {% include greeting with name=name %}"
      ],
      "params": {
        "name": "world"
      },
      "expected_output": "Hello world!\n"
    },
    {
      "name": "inline_template_with_typed_vars",
      "description": "Inline template with typed parameters (str and int)",
      "template_lines": [
        "---",
        "params:",
        "  - label = str",
        "  - count = int",
        "---",
        "> {% tmpl row %}",
        "---",
        "params:",
        "  - label = str",
        "  - count = int",
        "---",
        "- {{ label }}: {{ count }}",
        "",
        "> {% /tmpl %}",
        "",
        "> {% include row with label=label, count=count %}"
      ],
      "params": {
        "label": "tasks",
        "count": 42
      },
      "expected_output": "- tasks: 42\n"
    },
    {
      "name": "inline_template_type_mismatch",
      "description": "Passing a str where int is expected should produce a type mismatch error",
      "template_lines": [
        "---",
        "params: [name = str]",
        "---",
        "> {% tmpl row %}",
        "---",
        "params: [count = int]",
        "---",
        "{{ count }}",
        "",
        "> {% /tmpl %}",
        "",
        "> {% include row with count=name %}"
      ],
      "params": {
        "name": "oops"
      },
      "expected_error": "type mismatch"
    },
    {
      "name": "inline_template_for_loop",
      "description": "Inline template with for-each iteration over a list",
      "template_lines": [
        "---",
        "params: [items = list(str)]",
        "---",
        "> {% tmpl item %}",
        "---",
        "params: [it = str]",
        "---",
        "- {{ it }}",
        "",
        "> {% /tmpl %}",
        "",
        "> {% include item for it in items %}"
      ],
      "params": {
        "items": [
          "a",
          "b",
          "c"
        ]
      },
      "expected_output": "- a\n- b\n- c\n"
    },
    {
      "name": "inline_template_used_twice",
      "description": "Same inline template included at two different sites",
      "template_lines": [
        "---",
        "params: []",
        "---",
        "> {% tmpl sep %}",
        "---",
        "params: []",
        "---",
        "---",
        "",
        "> {% /tmpl %}",
        "",
        "A",
        "",
        "> {% include sep %}",
        "",
        "B",
        "",
        "> {% include sep %}"
      ],
      "params": {},
      "expected_output": "A\n---\nB\n---\n"
    },
    {
      "name": "raw_block_inside_inline_template",
      "description": "Raw blocks inside inline templates preserve literal content",
      "template_lines": [
        "---",
        "params: []",
        "---",
        "> {% tmpl code %}",
        "---",
        "params: []",
        "---",
        "",
        "> {% raw %}",
        "",
        "{{ not_processed }}",
        "",
        "> {% /raw %}",
        "",
        "> {% /tmpl %}",
        "",
        "> {% include code %}"
      ],
      "params": {},
      "expected_output": "{{ not_processed }}\n"
    },
    {
      "name": "tmpl_inside_raw_is_literal",
      "description": "tmpl tags inside raw blocks are treated as literal text",
      "template_lines": [
        "---",
        "params: []",
        "---",
        "",
        "> {% raw %}",
        "",
        "{% tmpl fake %}",
        "this is not a template",
        "{% /tmpl %}",
        "",
        "> {% /raw %}"
      ],
      "params": {},
      "expected_output": "{% tmpl fake %}\nthis is not a template\n{% /tmpl %}\n"
    },
    {
      "name": "tmpl_definition_produces_no_output",
      "description": "The tmpl definition itself produces no output; only the include does",
      "template_lines": [
        "---",
        "params: []",
        "---",
        "> {% tmpl unused_but_included_later %}",
        "---",
        "params: []",
        "---",
        "invisible",
        "",
        "> {% /tmpl %}",
        "",
        "visible",
        "",
        "> {% include unused_but_included_later %}"
      ],
      "params": {},
      "expected_output": "visible\ninvisible\n"
    },
    {
      "name": "comment_in_template_strips_cleanly",
      "description": "Comments are stripped without leaving extra whitespace",
      "template_lines": [
        "---",
        "params: [x = str]",
        "---",
        "before{# a comment #}after {{ x }}"
      ],
      "params": {
        "x": "!"
      },
      "expected_output": "beforeafter !"
    },
    {
      "name": "inline_template_name_not_flagged_as_undeclared",
      "description": "Inline template names must not trigger undeclared variable errors",
      "template_lines": [
        "---",
        "params: [name = str]",
        "---",
        "> {% tmpl greeting %}",
        "---",
        "params: [name = str]",
        "---",
        "Hello {{ name }}!",
        "",
        "> {% /tmpl %}",
        "",
        "> {% include greeting with name=name %}"
      ],
      "params": {
        "name": "world"
      },
      "expected_output": "Hello world!\n"
    },
    {
      "name": "circular_inline_includes",
      "description": "Circular inline templates should exceed max include depth and fail",
      "template_lines": [
        "---",
        "params: []",
        "---",
        "> {% tmpl a %}",
        "---",
        "params: []",
        "---",
        "> {% include b %}",
        "",
        "> {% /tmpl %}",
        "> {% tmpl b %}",
        "---",
        "params: []",
        "---",
        "> {% include a %}",
        "",
        "> {% /tmpl %}",
        "> {% include a %}"
      ],
      "params": {},
      "expected_error": "maximum include depth"
    },
    {
      "name": "missing_inline_include",
      "description": "Including an inline template that does not exist should fail",
      "template_lines": [
        "---",
        "params: []",
        "---",
        "> {% include non_existent_tmpl %}"
      ],
      "params": {},
      "expected_error": "non_existent_tmpl"
    },
    {
      "name": "inline_tmpl_wrong_type",
      "description": "Passing wrong parameter type to inline template should fail type checking",
      "template_lines": [
        "---",
        "params: [items = list(str)]",
        "---",
        "> {% tmpl row %}",
        "---",
        "params: [x = int]",
        "---",
        "{{ x }}",
        "",
        "> {% /tmpl %}",
        "> {% include row with x=items %}"
      ],
      "params": {
        "items": [
          "a",
          "b"
        ]
      },
      "expected_error": "type mismatch"
    },
    {
      "name": "inline_tmpl_complex_struct_and_consts",
      "description": "Inline template accessing its own consts and formatting complex struct param",
      "template_lines": [
        "---",
        "params: [user = struct(name = str, role = str)]",
        "---",
        "> {% tmpl card %}",
        "---",
        "params: [u = struct(name = str, role = str)]",
        "consts:",
        "  - BADGE = str := \"[VERIFIED]\"",
        "---",
        "{{ BADGE }} {{ u.name }} ({{ u.role }})",
        "",
        "> {% /tmpl %}",
        "> {% include card with u=user %}"
      ],
      "params": {
        "user": {
          "name": "Eve",
          "role": "Admin"
        }
      },
      "expected_output": "[VERIFIED] Eve (Admin)\n"
    },
    {
      "name": "deeply_nested_inline_includes",
      "description": "Deeply nested inline templates calling each other across 3 levels",
      "template_lines": [
        "---",
        "params: [val = str]",
        "---",
        "> {% tmpl l3 %}",
        "---",
        "params: [v = str]",
        "---",
        "L3:{{ v }}",
        "",
        "> {% /tmpl %}",
        "> {% tmpl l2 %}",
        "---",
        "params: [v = str]",
        "---",
        "L2->{%- include l3 with v=v -%}",
        "",
        "> {% /tmpl %}",
        "> {% tmpl l1 %}",
        "---",
        "params: [v = str]",
        "---",
        "L1->{%- include l2 with v=v -%}",
        "",
        "> {% /tmpl %}",
        "> {%- include l1 with v=val -%}"
      ],
      "params": {
        "val": "core"
      },
      "expected_output": "L1->L2->L3:core\n"
    },
    {
      "name": "inline_tmpl_whitespace_stripping_complex",
      "description": "Complex whitespace stripping around inline templates and comments",
      "template_lines": [
        "---",
        "params: [x = str]",
        "---",
        "> {% tmpl tag %}",
        "---",
        "params: [t = str]",
        "---",
        "[{{ t }}]",
        "",
        "> {% /tmpl %}",
        "",
        "Start{# comment #}{%- include tag with t=x -%}End"
      ],
      "params": {
        "x": "mid"
      },
      "expected_output": "Start[mid]\nEnd"
    }
  ]
}