{
  "tests": [
    {
      "name": "include_correct_types_pass",
      "description": "Passing the correct type to a file-based include should succeed",
      "files": {
        "typed.tmpl.md": [
          "---",
          "params: [count = int]",
          "---",
          "{{ count }}"
        ]
      },
      "parent_template_lines": [
        "---",
        "params: [num = int]",
        "---",
        "> {% include [typed](./typed.tmpl.md) with count=num %}"
      ],
      "params": {
        "num": 42
      },
      "expected_output": "42"
    },
    {
      "name": "include_with_defaults",
      "description": "File-based include where a parameter has a default value and is not explicitly passed",
      "files": {
        "greet.tmpl.md": [
          "---",
          "params:",
          "  - name = str",
          "  - greeting = str := \"Hi\"",
          "---",
          "{{ greeting }} {{ name }}!"
        ]
      },
      "parent_template_lines": [
        "---",
        "params: [name = str]",
        "---",
        "> {% include [greet](./greet.tmpl.md) with name=name %}"
      ],
      "params": {
        "name": "World"
      },
      "expected_output": "Hi World!"
    },
    {
      "name": "include_override_takes_precedence",
      "description": "Explicitly passing a parameter overrides its default value",
      "files": {
        "greet.tmpl.md": [
          "---",
          "params:",
          "  - name = str",
          "  - greeting = str := \"Hi\"",
          "---",
          "{{ greeting }} {{ name }}!"
        ]
      },
      "parent_template_lines": [
        "---",
        "params:",
        "  - name = str",
        "  - greeting = str",
        "---",
        "> {% include [greet](./greet.tmpl.md) with name=name, greeting=greeting %}"
      ],
      "params": {
        "name": "World",
        "greeting": "Hey"
      },
      "expected_output": "Hey World!"
    },
    {
      "name": "contract_rejects_missing_params",
      "description": "Including a template without providing required parameters should produce an error",
      "files": {
        "needs_vars.tmpl.md": [
          "---",
          "params: [title = str, count = int]",
          "---",
          "{{ title }} ({{ count }})"
        ]
      },
      "parent_template_lines": [
        "---",
        "params: []",
        "---",
        "> {% include [needs_vars](./needs_vars.tmpl.md) %}"
      ],
      "params": {},
      "expected_error": "title"
    },
    {
      "name": "circular_includes_rejected",
      "description": "Circular file-based includes should exceed max include depth and fail",
      "files": {
        "a.tmpl.md": [
          "---",
          "params: []",
          "---",
          "> {% include [b](./b.tmpl.md) %}"
        ],
        "b.tmpl.md": [
          "---",
          "params: []",
          "---",
          "> {% include [a](./a.tmpl.md) %}"
        ]
      },
      "parent_template_lines": [
        "---",
        "params: []",
        "---",
        "> {% include [a](./a.tmpl.md) %}"
      ],
      "params": {},
      "expected_error": "maximum include depth"
    },
    {
      "name": "missing_include_file_rejected",
      "description": "Including a non-existent template file should produce an error containing the filename",
      "files": {},
      "parent_template_lines": [
        "---",
        "params: []",
        "---",
        "> {% include [missing](./non_existent_file.tmpl.md) %}"
      ],
      "params": {},
      "expected_error": "non_existent_file.tmpl.md"
    },
    {
      "name": "include_wrong_type_rejected",
      "description": "Passing a string to an included template expecting an integer should fail type checking",
      "files": {
        "num.tmpl.md": [
          "---",
          "params: [x = int]",
          "---",
          "{{ x }}"
        ]
      },
      "parent_template_lines": [
        "---",
        "params: [val = str]",
        "---",
        "> {% include [num](./num.tmpl.md) with x=val %}"
      ],
      "params": {
        "val": "not a number"
      },
      "expected_error": "type mismatch"
    },
    {
      "name": "include_with_consts",
      "description": "Included template constants should be accessible in its own body",
      "files": {
        "consts.tmpl.md": [
          "---",
          "params: []",
          "consts:",
          "  - API_URL = str := \"https://api.example.com\"",
          "---",
          "URL: {{ API_URL }}"
        ]
      },
      "parent_template_lines": [
        "---",
        "params: []",
        "---",
        "> {% include [consts](./consts.tmpl.md) %}"
      ],
      "params": {},
      "expected_output": "URL: https://api.example.com"
    },
    {
      "name": "deeply_nested_includes",
      "description": "Deeply nested includes passing parameters down 3 levels",
      "files": {
        "level3.tmpl.md": [
          "---",
          "params: [val = str]",
          "---",
          "L3: {{ val }}"
        ],
        "level2.tmpl.md": [
          "---",
          "params: [val = str]",
          "---",
          "L2 -> {% include [l3](./level3.tmpl.md) with val=val %}"
        ],
        "level1.tmpl.md": [
          "---",
          "params: [val = str]",
          "---",
          "L1 -> {% include [l2](./level2.tmpl.md) with val=val %}"
        ]
      },
      "parent_template_lines": [
        "---",
        "params: [msg = str]",
        "---",
        "> {% include [l1](./level1.tmpl.md) with val=msg %}"
      ],
      "params": {
        "msg": "deeply nested"
      },
      "expected_output": "L1 -> L2 -> L3: deeply nested"
    },
    {
      "name": "include_complex_types_list_struct",
      "description": "Included template rendering complex list of structs",
      "files": {
        "table.tmpl.md": [
          "---",
          "params: [rows = list(name = str, score = int)]",
          "---",
          "> {% for row in rows %}",
          "",
          "- {{ row.name }}: {{ row.score }}",
          "",
          "> {% /for %}"
        ]
      },
      "parent_template_lines": [
        "---",
        "params: [data = list(name = str, score = int)]",
        "---",
        "> {% include [table](./table.tmpl.md) with rows=data %}"
      ],
      "params": {
        "data": [
          {
            "name": "Alice",
            "score": 100
          },
          {
            "name": "Bob",
            "score": 95
          }
        ]
      },
      "expected_output": "- Alice: 100\n- Bob: 95\n"
    }
  ]
}